generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: pooled `DATABASE_URL` for the app; direct (non-pooler host) for `prisma migrate`. Same credentials as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// --- Enums ---

enum LeadType {
  booking
  newsletter
  contact
}

enum LeadStatus {
  new
  contacted
  booked
  closed
  archived
}

enum BookingRequestStatus {
  new
  contacted
  booked
  completed
  cancelled
}

enum NewsletterSubscriberStatus {
  active
  unsubscribed
}

enum ContentPageStatus {
  draft
  published
}

enum BlogPostAdminStatus {
  draft
  published
}

enum LessonScheduleLocationType {
  studio
  online
  home
  retreat
}

enum SiteUserStatus {
  active
  inactive
}

// --- Core CRM ---

model Lead {
  id        String     @id @default(uuid())
  type      LeadType
  status    LeadStatus @default(new)
  name      String?
  phone     String?
  email     String?
  message   String?    @db.Text
  source    String?
  metadata  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  bookingRequest BookingRequest?
  contactInquiry ContactInquiry?
  linkedNewsletterSignup NewsletterSubscriber? @relation("NewsletterSignupLead")

  @@index([type, status])
  @@index([createdAt])
}

model BookingRequest {
  id                     String                 @id @default(uuid())
  leadId                 String                 @unique
  lead                   Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  offeringId             String
  offeringTitle          String
  bookingKind            String
  date                   String
  timeSlot               String
  timezone               String                 @default("Asia/Jerusalem")
  reference              String
  notes                  String                 @db.Text
  preferredContactMethod String?
  status                 BookingRequestStatus   @default(new)
  internalNotes          String?                @db.Text
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  participants BookingParticipant[]

  @@index([status])
  @@index([createdAt])
}

model BookingParticipant {
  id               String   @id @default(uuid())
  bookingRequestId String
  bookingRequest   BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  name             String
  phone            String?
  email            String?
  status           String   @default("pending")
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([bookingRequestId])
}

model NewsletterSubscriber {
  id               String                     @id @default(uuid())
  email            String                     @unique
  source           String
  language         String
  subscribedAt     DateTime                   @default(now())
  status           NewsletterSubscriberStatus @default(active)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  lastSignupLeadId String?                    @unique
  lastSignupLead   Lead?                      @relation("NewsletterSignupLead", fields: [lastSignupLeadId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([email])
}

model ContactInquiry {
  id              String   @id @default(uuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name            String
  phone           String?
  email           String?
  interestType    String
  preferredMethod String
  message         String   @db.Text
  source          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- Catalog ---

model LessonService {
  id              String   @id @default(uuid())
  slug            String   @unique
  titleHe         String
  titleEn         String
  descriptionHe   String   @db.Text
  descriptionEn   String   @db.Text
  type            String
  durationMinutes Int
  price           Decimal  @db.Decimal(12, 2)
  currency        String   @default("ILS")
  active          Boolean  @default(true)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedules LessonSchedule[]

  @@index([active, featured])
}

model LessonSchedule {
  id            String                     @id @default(uuid())
  serviceId     String
  service       LessonService              @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  date          String
  startTime     String
  endTime       String
  capacity      Int                        @default(1)
  bookedCount   Int                        @default(0)
  locationType  LessonScheduleLocationType @default(studio)
  locationText  String?
  active        Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([serviceId, date])
  @@index([date, active])
}

// --- CMS ---

model ContentPage {
  id               String            @id @default(uuid())
  slug             String            @unique
  titleHe          String
  titleEn          String
  bodyHe           String            @db.Text
  bodyEn           String            @db.Text
  seoTitleHe       String?
  seoTitleEn       String?
  seoDescriptionHe String?           @db.Text
  seoDescriptionEn String?           @db.Text
  status           ContentPageStatus @default(draft)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model BlogPostAdmin {
  id          String              @id @default(uuid())
  slug        String              @unique
  titleHe     String
  titleEn     String
  excerptHe   String              @db.Text
  excerptEn   String              @db.Text
  category    String
  tags        String[]            @default([])
  status      BlogPostAdminStatus @default(draft)
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// --- Users (future public auth) ---

model SiteUser {
  id          String         @id @default(uuid())
  name        String?
  email       String?        @unique
  phone       String?
  role        String         @default("user")
  lastLoginAt DateTime?
  createdAt   DateTime       @default(now())
  source      String?
  status      SiteUserStatus @default(active)
}

// --- Admin accounts (optional DB users; login uses env by default) ---

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String?
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  actor      String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}
