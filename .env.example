# Public site URL (metadata, sitemap, OG). Required on Vercel production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Neon Postgres (server only; never commit real URL) ---
# Optional in local dev if using file-based lead store; required on Vercel production.
# Pooled URL (host often contains "-pooler") — used by the running app.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DB?sslmode=require
# Direct URL (same user/password/db; host usually has NO "-pooler") — used by `prisma migrate`.
# In Neon: Dashboard → connect → copy "direct" / non-pooled connection string.
DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DB?sslmode=require

# --- Admin (server only) ---
# Vercel production: ADMIN_SESSION_SECRET 24+ chars. Legacy: ADMIN_ACCESS_KEY 16+ if secret unset.
ADMIN_SESSION_SECRET=replace-with-long-random-secret-min-24-chars-in-production

# Operator login — strong password (min 8 dev / 12 production on Vercel).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# Legacy single-key setups (optional): if ADMIN_SESSION_SECRET is unset, ADMIN_ACCESS_KEY may be used
# as session secret for migration only.

# --- Lead storage override (optional) ---
# When DATABASE_URL is set, Neon/Prisma is used by default.
# Force JSON file store: LEADS_STORAGE_DRIVER=file
# LEADS_DATA_DIR=.data

# Booking integrations (optional)
# CALCOM_API_KEY=
# GOOGLE_CALENDAR_SA_JSON=
# PAYPLUS_API_KEY=
# TRANZILA_TERMINAL=
